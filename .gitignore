# Rust / Swift build artifacts under path-dependency plugins (if no local .gitignore)
plugins/**/target/
plugins/**/ios/.build/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history

# Generated Mac App Store entitlements (from .template + APPLE_TEAM_ID); see scripts/gen-macos-appstore-entitlements.cjs
src-tauri/Entitlements.macos-appstore.plist

# Apple signing & certificates — never commit (see src-tauri/signing/README.md)
# Ignore everything in signing/ except the README
src-tauri/signing/*
!src-tauri/signing/README.md
# Same artifacts anywhere in the repo (Xcode exports, Downloads, etc.)
*.provisionprofile
*.mobileprovision
*.p12
*.cer
*.certSigningRequest
*.csr
AuthKey_*.p8
# App Store Connect API keys (any folder)
**/AuthKey_*.p8
