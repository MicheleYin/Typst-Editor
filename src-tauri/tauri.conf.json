{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Typst Editor",
  "version": "0.1.0",
  "identifier": "com.micheleyin.typst-editor",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Typst Editor",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "targets": "all",
    "resources": ["resources/fonts/bundled"],
    "macOS": {
      "entitlements": "Entitlements.macos-direct.plist",
      "minimumSystemVersion": "11.0",
      "hardenedRuntime": true
    },
    "iOS": {
      "minimumSystemVersion": "14.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
